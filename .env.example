# PostgreSQL connection string (Neon, local Postgres, etc.)
# Neon example: postgresql://user:pass@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/baby_tracker"

# Auth.js / NextAuth v5 — generate with: npx auth secret
AUTH_SECRET="replace-me-with-a-long-random-string"

# Base URL of the app (used for invite links). No trailing slash.
AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional Google OAuth — leave blank to hide the Google sign-in button
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
